    {
      "parameters": {
        "jsCode": "// Input: `items[0].json.text` containing the code‑block string\n// Output: parsed JSON object (e.g., { linkedin_post: \"...\" })\n\nconst text = $input.first().json.content.parts[0].text;\n\n// Step 1: Remove ```json and backticks, if present\nconst stripped = text\n  .replace(/^```json\\s*/i, '')\n  .replace(/```+$/, '')\n  .trim();\n\n// Step 2: Try to parse JSON safely\nlet parsed;\ntry {\n  parsed = JSON.parse(stripped);\n} catch (err) {\n  throw new Error(`Failed to parse JSON from text: ${err.message}. Input: ${stripped.substring(0, 200)}...`);\n}\n\n// Step 3: Return as a single item in n8n format\nreturn [\n  {\n    json: parsed,\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
