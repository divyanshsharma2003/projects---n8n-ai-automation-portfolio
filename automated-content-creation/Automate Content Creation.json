      "parameters": {
        "jsCode": "const items = $input.all().map((item) => item.json);\nconst topicData = $(\"Fetch the Topic\").all().map((item) => item.json)[0];\nconst updatedItems = items.map((item) => {\n  let systemPrompt = item[\"System Prompt\"];\n  let userPrompt = item[\"User Prompt\"];\n\n  for(const key in topicData){\n    const regex = RegExp(`{{${key}}}`, \"g\");\n    systemPrompt = systemPrompt.replace(regex, topicData[key]);\n    userPrompt = userPrompt.replace(regex, topicData[key]);\n  }\n  item[\"System Prompt\"] = systemPrompt;\n  item[\"User Prompt\"] = userPrompt;\n  return {json : item};\n});\n\nreturn updatedItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
