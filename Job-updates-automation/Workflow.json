    {
      "parameters": {
        "jsCode": "// Data from two different previous nodes\nconst metaItem = $(\"Creating Composite Key (Deduplicaiton)\").first().json;\nconst outputItem = $(\"Information Extractor\").first().json;\n\n// Combine both into one clean object\nconst newItem = {\n  ...metaItem,\n  ...(outputItem.output || {})\n};\n\nconst newKey = newItem.__key;\n\n// Existing rows coming into this Code node from Google Sheets\nconst existingRows = $input.all();\n\n// If sheet is empty, allow insert\nif (!existingRows || existingRows.length === 0) {\n  return [{ json: newItem }];\n}\n\n// If only one row exists\nif (existingRows.length === 1) {\n  const row = existingRows[0].json;\n  const comp = row['Company Name'] || '';\n  const role = row['Job Title'] || '';\n  const existingKey = `${comp}||${role}`.toLowerCase().trim();\n\n  if (existingKey === newKey) {\n    return [];\n  }\n\n  return [{ json: newItem }];\n}\n\n// If multiple rows exist\nconst isDuplicate = existingRows.some(item => {\n  const comp = item.json['Company Name'] || '';\n  const role = item.json['Job Title'] || '';\n  const existingKey = `${comp}||${role}`.toLowerCase().trim();\n  return existingKey === newKey;\n});\n\nif (isDuplicate) {\n  return [];\n}\n\nreturn [{ json: newItem }];"
      },
