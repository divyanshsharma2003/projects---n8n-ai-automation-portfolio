      "parameters": {
        "jsCode": "// Get input from previous node\nconst rawInput = $input.first().json.content.parts[0].text;\n\n// Remove markdown code fences if present\nconst cleaned = rawInput\n  .replace(/^```json\\s*/i, '')\n  .replace(/^```\\s*/i, '')\n  .replace(/\\s*```$/, '')\n  .trim();\n\n// Parse JSON\nconst parsed = JSON.parse(cleaned);\n\n// Return structured output\nreturn [\n  {\n    json: {\n      suggestion: parsed.suggestion,\n      score: parsed.job_applicability_score?.score,\n      reason: parsed.job_applicability_score?.reason\n    }\n  }\n];"
      },
