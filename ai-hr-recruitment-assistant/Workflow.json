      "parameters": {
        "promptType": "define",
        "text": "=Job posting details :\n{{ $json.content }}\n\nHere is the Candidate Profile Summary :\n{{ $('Profile Summarization').item.json.output.text }}\n\nYou MUST respond ONLY with valid JSON, with no extra keys, comments, code blocks, or explanations.\nDo not wrap the JSON in ``` or any other formatting.",
        "messages": {
          "messageValues": [
            {
              "message": "You are an HR expert and you need to understand if the candidate aligns with the job profile that company has sought. You have to score the candidate alignment with the job profile in the range of 1 to 10, where 1 means, candidate does not align with what is required, while 10 means that they are the ideal candidate for the job and they fully reflect the job profile. Also , in the 'consideration' field briefly and concisely explain your reasoning behind the score given.\n\nYou MUST respond ONLY with valid JSON that matches this schema, with no extra keys, comments, code blocks, or explanations.\nDo not wrap the JSON in ``` or any other formatting, wrap it as per the given format of json:\n\n{\n\t\"type\": \"object\",\n\t\"properties\": {\n\t\t\"ai_resume_score\": {\n\t\t\t\"type\": \"string\"\n\t\t},\n\t\t\"ai_evaluation\": {\n\t\t\t\"type\": \"string\"\n\t\t}\n\t}\n}"
            }
          ]
        },
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        1856,
        816
      ],
      "id": "7a114b8f-dd22-4127-9f01-4ed4127147b9",
